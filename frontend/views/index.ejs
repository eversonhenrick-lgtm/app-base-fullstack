<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema da Pizzaria</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

<header class="hero">
    <div class="hero-overlay">
        <h1>Sistema da Pizzaria</h1>
        <p>Gerenciamento de Clientes, Produtos, Pedidos e Usuários</p>
    </div>
</header>

<div class="container painel-principal mb-5">

    <ul class="nav nav-tabs justify-content-center">
        <li class="nav-item">
            <button class="nav-link active" onclick="mostrarSecao('clientes')">
                Clientes
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="mostrarSecao('produtos')">
                Produtos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="mostrarSecao('pedidos')">
                Pedidos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="mostrarSecao('usuarios')">
                Usuários
            </button>
        </li>
    </ul>

    <div class="mt-4">

        <div id="clientes">
            <h3 class="text-center mb-4">Clientes</h3>

            <form id="formCliente" onsubmit="event.preventDefault(); criarCliente();">
                <input type="hidden" id="clienteId">
                <input class="form-control mb-2" id="nome" placeholder="Nome">
                <input class="form-control mb-2" id="telefone" placeholder="Telefone">
                <input class="form-control mb-3" id="endereco" placeholder="Endereço">

                <button type="submit" class="btn btn-warning w-100">
                    Salvar Cliente
                </button>
            </form>

            <table class="table table-hover mt-4">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Telefone</th>
                        <th>Endereço</th>
                    </tr>
                </thead>
                <tbody id="listaClientes"></tbody>
            </table>
        </div>

        <div id="produtos" style="display:none">
            
            <div class="mx-auto" style="max-width: 550px; margin-top: 0;">
                
                <div class="mb-4 text-center">
                    <h3 class="fw-bold"><i class="fas fa-pizza-slice me-2"></i>Cadastrar Produto</h3>
                    <p style="color: #94a3b8; font-size: 0.95rem;">Adicione novos itens e valores ao cardápio</p>
                    <hr style="border-color: #334155; opacity: 0.5;">
                </div>

                <form id="formProduto">
                    
                    <div class="mb-3">
                        <label for="nome" class="form-label fw-semibold" style="color: white;">Nome do Produto</label>
                        <input type="text" class="form-control" id="nome" name="nome" placeholder="Ex: Pizza de Calabresa" required>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label for="categoria" class="form-label fw-semibold" style="color: white;">Categoria</label>
                            <select class="form-select form-control" id="categoria" name="categoria" required>
                                <option value="" disabled selected style="background: #1e293b;">Escolha...</option>
                                <option value="Pizza" style="background: #1e293b;">Pizzas</option>
                                <option value="Bebida" style="background: #1e293b;">Bebidas</option>
                            </select>
                        </div>

                        <div class="col-6 mb-3">
                            <label for="preco" class="form-label fw-semibold" style="color: white;">Preço (R$)</label>
                            <input type="number" class="form-control" id="preco" name="preco" step="0.01" placeholder="45.90" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="imagem" class="form-label fw-semibold" style="color: white;">Link da Imagem (URL)</label>
                        <input type="url" class="form-control" id="imagem" name="imagem" placeholder="https://exemplo.com/foto.jpg">
                    </div>

                    <div class="mb-4">
                        <label for="descricao" class="form-label fw-semibold" style="color: white;">Descrição / Ingredientes</label>
                        <textarea class="form-control" id="descricao" name="descricao" rows="3" placeholder="Molho de tomate, mussarela, calabresa picada..."></textarea>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-warning btn-lg py-3">
                            Adicionar ao Cardápio
                        </button>
                    </div>

                </form>
            </div>

            <div class="w-100 mt-5">
                <h3 class="text-center mb-4 fw-bold" style="color: #ffc107;">Cardápio Pizza Itália</h3>
                
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="listaProdutos">
                    </div>
            </div>
        </div>

        <div id="pedidos" style="display:none">
            <h3>Pedidos</h3>
        </div>

        <div id="usuarios" style="display:none">
            <h3>Usuários</h3>
        </div>

    </div>
</div>
<div class="mx-auto mb-4" style="max-width: 550px;">
    <div class="input-group">
        <span class="input-group-text bg-dark text-warning border-secondary">
            <i class="fas fa-lock" id="iconeCadeado"></i>
        </span>
        <input type="password" id="tokenSwagger" class="form-control bg-dark text-white border-secondary" placeholder="Cole aqui o Token JWT do Swagger">
        <button class="btn btn-warning" type="button" onclick="guardarToken()">
            <i class="fas fa-key me-1"></i> Autenticar
        </button>
    </div>
    <small class="text-muted d-block mt-1 ps-2">
        <i class="fas fa-info-circle me-1"></i> Insira o token para liberar as permissões do banco de dados.
    </small>
</div>

<script src="/js/main.js"></script>
<script src="/js/clientes.js"></script>
<script src="/js/produtos.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>