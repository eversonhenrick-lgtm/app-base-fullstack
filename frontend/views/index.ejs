<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema da Pizzaria</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

    <!-- ================= HERO ================= -->
    <header class="hero">
        <div class="container text-center py-5">

            <h1 class="display-4 fw-bold text-white">
                🍕 Sistema da Pizzaria
            </h1>

            <p class="lead text-white">
                Gerencie clientes, produtos, pedidos e funcionários
            </p>

        </div>
    </header>

    <!-- ================= MENU ================= -->
    <div class="container painel-principal my-5">

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">

                <ul class="nav nav-pills justify-content-center gap-2">

                    <li class="nav-item">
                        <button class="nav-link active" onclick="mostrarSecao('clientes')">
                            👤 Clientes
                        </button>
                    </li>

                    <li class="nav-item">
                        <button class="nav-link" onclick="mostrarSecao('produtos')">
                            🍕 Produtos
                        </button>
                    </li>

                    <li class="nav-item">
                        <button class="nav-link" onclick="mostrarSecao('pedidos')">
                            📦 Pedidos
                        </button>
                    </li>

                    <li class="nav-item">
                        <button class="nav-link" onclick="mostrarSecao('usuarios')">
                            👨‍💼 Funcionários
                        </button>
                    </li>

                </ul>

            </div>
        </div>

        <!-- ================= CLIENTES ================= -->
        <section id="clientes">

            <div class="text-center mb-4">
                <h3 class="text-warning fw-bold">👤 Clientes Registrados</h3>
                <p class="text-muted">Histórico de clientes cadastrados no sistema</p>
            </div>

            <div class="card shadow-sm border-0 p-3">
                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Telefone</th>
                            <th>Endereço</th>
                        </tr>
                    </thead>

                    <tbody id="listaClientes"></tbody>

                </table>
            </div>

        </section>

        <!-- ================= PRODUTOS ================= -->
        <section id="produtos" style="display:none">

            <!-- FORM ADMIN -->
            <div id="painelAdminProduto"
                class="card shadow-sm border-0 p-4 mb-4 mx-auto"
                style="max-width: 600px; display:none;">

                <h3 class="text-center text-warning fw-bold mb-4">
                    🍕 Cadastrar Produto
                </h3>

                <form id="formProduto">

                    <input class="form-control mb-2" id="nome" placeholder="Nome do produto">

                    <div class="row g-2 mb-2">

                        <div class="col-md-6">
                            <select class="form-control" id="categoria">
                                <option value="Pizza">Pizza</option>
                                <option value="Bebida">Bebida</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <input class="form-control" id="preco" placeholder="Preço">
                        </div>

                    </div>

                    <input class="form-control mb-2" id="imagem" placeholder="URL da imagem">

                    <textarea class="form-control mb-3" id="descricao"
                        placeholder="Descrição"></textarea>

                    <button class="btn btn-warning w-100">
                        Adicionar Produto
                    </button>

                </form>
            </div>

            <!-- TITULO -->
            <div class="text-center mb-4">
                <h3 class="text-warning fw-bold">🍕 Cardápio</h3>
                <p class="text-muted">Produtos cadastrados no sistema</p>
            </div>

            <!-- LISTA PRODUTOS -->
            <div class="row g-4" id="listaProdutos"></div>

        </section>

        <!-- ================= PEDIDOS ================= -->
        <section id="pedidos" style="display:none">

            <div class="text-center mb-4">
                <h3 class="text-warning fw-bold">📦 Pedidos</h3>
                <p class="text-muted">Acompanhe e gerencie os pedidos dos clientes</p>
            </div>

            <div id="listaPedidos"
                class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            </div>

        </section>

        <!-- ================= USUÁRIOS ================= -->
        <section id="usuarios" style="display:none">

            <div class="card shadow-sm border-0 p-4 mb-4">

                <h3 class="text-center text-warning fw-bold mb-4">
                    👨‍💼 Funcionários do Sistema
                </h3>

                <form id="formUsuario">

                    <input type="hidden" id="usuarioId">

                    <div class="row g-2">

                        <div class="col-md-4">
                            <input class="form-control" id="usuarioNome" placeholder="Nome">
                        </div>

                        <div class="col-md-4">
                            <input class="form-control" id="usuarioEmail" placeholder="E-mail">
                        </div>

                        <div class="col-md-4">
                            <input type="password" class="form-control" id="usuarioSenha"
                                placeholder="Senha">
                        </div>

                    </div>

                    <button class="btn btn-warning w-100 mt-3" type="submit">
                        ➕ Cadastrar Funcionário
                    </button>

                </form>

            </div>

            <div class="card shadow-sm border-0 p-3">

                <h5 class="text-warning mb-3">📋 Funcionários Cadastrados</h5>

                <table class="table table-hover align-middle mb-0">

                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>E-mail</th>
                            <th>Ações</th>
                        </tr>
                    </thead>

                    <tbody id="listaUsuarios"></tbody>

                </table>

            </div>

        </section>

    </div>

    <!-- ================= AUTENTICAÇÃO ================= -->
    <div class="container mb-5">

        <div class="card shadow-sm border-0">

            <div class="card-body">

                <h5 class="mb-3">🔐 Autenticação</h5>

                <div class="input-group">

                    <span class="input-group-text bg-dark text-warning">
                        <i class="fas fa-lock"></i>
                    </span>

                    <input type="password" id="tokenSwagger"
                        class="form-control bg-dark text-white"
                        placeholder="Cole o token JWT">

                    <button class="btn btn-warning" onclick="guardarToken()">
                        Autenticar
                    </button>

                </div>

                <small class="text-muted">
                    Token necessário para permissões do sistema
                </small>

            </div>

        </div>

    </div>

    <!-- ================= SCRIPTS ================= -->
    <script src="/js/main.js"></script>
    <script src="/js/clientes.js"></script>
    <script src="/js/produtos.js"></script>
    <script src="/js/cardapio.js"></script>
    <script src="/js/usuarios.js"></script>
    <script src="/js/gerenciar-pedidos.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>