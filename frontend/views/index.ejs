<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema da Pizzaria</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

<!-- ================= HERO ================= -->
<header class="hero text-center text-white py-5">
    <div class="hero-overlay">
        <h1 class="fw-bold">🍕 Sistema da Pizzaria</h1>
        <p>Gerencie clientes, produtos, pedidos e usuários</p>
    </div>
</header>

<!-- ================= MENU ================= -->
<div class="container painel-principal my-4">

    <ul class="nav nav-pills justify-content-center gap-2 mb-4">
        <li class="nav-item">
            <button class="nav-link active" onclick="mostrarSecao('clientes')">Clientes</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="mostrarSecao('produtos')">Produtos</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="mostrarSecao('pedidos')">Pedidos</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="mostrarSecao('usuarios')">Usuários</button>
        </li>
    </ul>

    <!-- ================= CLIENTES ================= -->
    <section id="clientes">

        <div class="card p-4 mb-4">
            <h3 class="text-center mb-3">👤 Clientes</h3>

            <form id="formCliente" onsubmit="event.preventDefault(); criarCliente();">
                <input type="hidden" id="clienteId">

                <div class="row g-2">
                    <div class="col-md-4">
                        <input class="form-control" id="nome" placeholder="Nome">
                    </div>
                    <div class="col-md-4">
                        <input class="form-control" id="telefone" placeholder="Telefone">
                    </div>
                    <div class="col-md-4">
                        <input class="form-control" id="endereco" placeholder="Endereço">
                    </div>
                </div>

                <button class="btn btn-warning w-100 mt-3">
                    Salvar Cliente
                </button>
            </form>
        </div>

        <div class="card p-3">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Telefone</th>
                        <th>Endereço</th>
                    </tr>
                </thead>
                <tbody id="listaClientes"></tbody>
            </table>
        </div>

    </section>

    <!-- ================= PRODUTOS + CARDÁPIO ================= -->
    <section id="produtos" style="display:none">

        <!-- ADMIN (CADASTRO) -->
        <div id="painelAdminProduto" class="card p-4 mb-4 mx-auto" style="max-width: 600px; display:none;">

            <h3 class="text-center mb-3">🍕 Cadastrar Produto</h3>

            <form id="formProduto">

                <input class="form-control mb-2" id="nome" placeholder="Nome do produto">

                <div class="row g-2 mb-2">
                    <div class="col-md-6">
                        <select class="form-control" id="categoria">
                            <option value="Pizza">Pizza</option>
                            <option value="Bebida">Bebida</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <input class="form-control" id="preco" placeholder="Preço">
                    </div>
                </div>

                <input class="form-control mb-2" id="imagem" placeholder="URL da imagem">
                <textarea class="form-control mb-3" id="descricao" placeholder="Descrição"></textarea>

                <button class="btn btn-warning w-100">
                    Adicionar Produto
                </button>

            </form>
        </div>

        <!-- CARDÁPIO (TODOS VEEM) -->
        <div class="text-center mb-3">
            <h3 class="text-warning">🍕 Cardápio</h3>
            <p class="text-muted">Escolha suas pizzas favoritas</p>
        </div>

        <div class="row g-4" id="listaProdutos"></div>

    </section>

    <!-- ================= PEDIDOS ================= -->
    <section id="pedidos" style="display:none">
        <h3 class="text-center">📦 Pedidos</h3>
    </section>

    <!-- ================= USUÁRIOS ================= -->
    <section id="usuarios" style="display:none">
        <h3 class="text-center">👨‍💼 Usuários</h3>
    </section>

</div>

<!-- ================= TOKEN ================= -->
<div class="container mb-4">
    <div class="input-group">
        <span class="input-group-text bg-dark text-warning">
            <i class="fas fa-lock"></i>
        </span>

        <input type="password" id="tokenSwagger"
               class="form-control bg-dark text-white"
               placeholder="Cole o token JWT">

        <button class="btn btn-warning" onclick="guardarToken()">
            Autenticar
        </button>
    </div>

    <small class="text-muted">
        Token necessário para permissões do sistema
    </small>
</div>

<!-- ================= SCRIPTS ================= -->
<script src="/js/main.js"></script>
<script src="/js/clientes.js"></script>
<script src="/js/produtos.js"></script>
<script src="/js/cardapio.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>