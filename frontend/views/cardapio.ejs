<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cardápio - Pizzaria</title>

    <link rel="stylesheet" href="/stylesheets/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<div class="container py-5">

    <!-- HEADER -->
    <div class="header-cardapio d-flex justify-content-between align-items-center mb-5">

        <div style="width:120px;"></div>

        <div class="text-center">

            <h1 class="titulo-cardapio mb-1">
                🍕 Cardápio
            </h1>

            <p class="subtitulo-cardapio mb-0">
                Escolha sua pizza favorita!
            </p>

        </div>

        <div class="d-flex gap-2">

            <a
                href="/meus-pedidos"
                class="btn btn-outline-primary shadow-sm"
            >
                📦 Meus Pedidos
            </a>

            <button
                class="btn btn-warning position-relative shadow-sm"
                id="btnCarrinho"
                type="button"
                aria-label="Abrir carrinho"
            >
                🛒 Carrinho

                <span
                    id="contadorCarrinho"
                    class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                >
                    0
                </span>

            </button>

        </div>

    </div>

    <!-- FILTROS -->
    <div class="d-flex justify-content-center gap-3 flex-wrap mb-4">

        <button class="btn btn-warning filtro-btn active">
            Todas
        </button>

        <button class="btn btn-outline-warning filtro-btn">
            Pizzas 🍕
        </button>

        <button class="btn btn-outline-primary filtro-btn">
            Bebidas 🥤
        </button>

    </div>

    <!-- BUSCA -->
    <div class="row justify-content-center mb-5">

        <div class="col-md-6">

            <input
                type="text"
                class="form-control form-control-lg shadow-sm"
                id="buscarProduto"
                placeholder="🔍 Buscar pizza, bebida ou sobremesa..."
                autocomplete="off"
            >

        </div>

    </div>

    <!-- PRODUTOS -->
    <div
        id="listaProdutos"
        class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4"
    >
    </div>

    <!-- INFO -->
    <div class="info-cardapio mt-5">

        <div class="row align-items-center">

            <div class="col-md-6">

                <h4 class="mb-1">
                    🚚 Entrega rápida e segura!
                </h4>

                <p class="mb-0 text-muted">
                    Peça suas pizzas favoritas no conforto da sua casa.
                </p>

            </div>

            <div class="col-md-6 text-md-end mt-3 mt-md-0">

                <strong class="me-3">
                    🔒 Pagamento seguro
                </strong>

                <strong>
                    💳 PIX e Cartão
                </strong>

            </div>

        </div>

    </div>

</div>

<!-- MODAL CARRINHO -->
<div
    class="modal fade"
    id="modalCarrinho"
    tabindex="-1"
    aria-hidden="true"
>

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    🛒 Meu Carrinho
                </h5>

                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                    aria-label="Fechar"
                ></button>

            </div>

            <div class="modal-body">

                <div id="itensCarrinho">

                    <p class="text-muted mb-0">
                        Seu carrinho está vazio.
                    </p>

                </div>

            </div>

            <div class="modal-footer">

                <strong id="totalCarrinho">
                    Total: R$ 0,00
                </strong>

                <button     
                    class="btn btn-success shadow-sm"
                    id="btnFinalizarPedido"
                >
                    Finalizar Pedido
                </button>

            </div>

        </div>

    </div>

</div>

<script src="/js/carrinho.js"></script>
<script src="/js/cardapio.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>