<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Sistema da Pizzaria</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body class="d-flex align-items-center justify-content-center vh-100" style="background-color: #0d1424;">

<div class="w-100 p-3" style="max-width: 450px;">

    <!-- ================= LOGIN ================= -->
    <div id="loginBox"
         class="card p-4 border-0 shadow"
         style="background-color: #141d30; border-radius: 12px;">

        <div class="card-body text-center text-white">

            <h2 class="fw-bold mb-1">Sistema da Pizzaria</h2>
            <p class="text-secondary small mb-4">
                Gerenciamento de Clientes, Produtos, Pedidos e Usuários
            </p>

            <form id="formLogin">
                <div class="mb-3 text-start">
                    <label class="form-label fw-semibold" style="color: #ffc107;">E-mail</label>
                    <input type="email" class="form-control bg-dark border-secondary text-white" id="email" required>
                </div>

                <div class="mb-4 text-start">
                    <label class="form-label fw-semibold" style="color: #ffc107;">Senha</label>
                    <input type="password" class="form-control bg-dark border-secondary text-white" id="senha" required>
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold py-2">
                    Entrar
                </button>
            </form>

            <button type="button"
                    class="btn btn-outline-light w-100 mt-2"
                    onclick="mostrarCadastro()">
                Criar conta
            </button>

        </div>
    </div>

    <!-- ================= CADASTRO ================= -->
    <div id="cadastroBox"
         class="card p-4 border-0 shadow mt-3"
         style="background-color: #141d30; border-radius: 12px; display:none;">

        <div class="card-body text-white">

            <h4 class="text-warning text-center mb-3">Criar Conta</h4>

            <form id="formCadastro">

                <input class="form-control mb-2 bg-dark text-white" id="nomeCadastro" placeholder="Nome completo">

                <input class="form-control mb-2 bg-dark text-white" id="emailCadastro" placeholder="E-mail">

                <input type="password" class="form-control mb-2 bg-dark text-white" id="senhaCadastro" placeholder="Senha">

                <div class="row g-2 mb-2">
                    <div class="col-md-4">
                        <input class="form-control bg-dark text-white" id="cepCadastro" placeholder="CEP">
                    </div>

                    <div class="col-md-8">
                        <input class="form-control bg-dark text-white" id="enderecoCadastro" placeholder="Endereço" readonly>
                    </div>
                    <div class="mb-2">
                        <input class="form-control bg-dark text-white" id="telefoneCadastro" placeholder="Telefone">
                    </div>
                </div>

                <button class="btn btn-warning w-100">
                    Cadastrar
                </button>

            </form>

            <button type="button"
                    class="btn btn-outline-light w-100 mt-2"
                    onclick="mostrarLogin()">
                Voltar para login
            </button>

        </div>
    </div>

</div>

<script src="/js/login-auth.js"></script>
<script src="/js/formCadastro.js"></script>

</body>
</html>