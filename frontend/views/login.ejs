<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Sistema da Pizzaria</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="d-flex align-items-center justify-content-center vh-100" style="background-color: #0d1424;">

    <div class="w-100 p-3" style="max-width: 450px;">
        <div class="card p-4 border-0 shadow" style="background-color: #141d30; border-radius: 12px;">
            <div class="card-body text-center text-white">
                
                <h2 class="fw-bold mb-1">Sistema da Pizzaria</h2>
                <p class="text-secondary small mb-4">Gerenciamento de Clientes, Produtos, Pedidos e Usuários</p>
                
                <form id="formLogin">
                    <div class="mb-3 text-start">
                        <label for="email" class="form-label fw-semibold" style="color: #ffc107;">E-mail</label>
                        <input type="email" class="form-control bg-dark border-secondary text-white" id="email" placeholder="Digite seu e-mail" required>
                    </div>
                    
                    <div class="mb-4 text-start">
                        <label for="senha" class="form-label fw-semibold" style="color: #ffc107;">Senha</label>
                        <input type="password" class="form-control bg-dark border-secondary text-white" id="senha" placeholder="Digite sua senha" required>
                    </div>
                    
                    <button type="submit" class="btn btn-warning w-100 fw-bold py-2">
                        Entrar
                    </button>
                </form>

            </div>
        </div>
    </div>

    <script src="/js/login-auth.js"></script>
</body>
</html>