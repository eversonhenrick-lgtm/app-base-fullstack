<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pizza Itália - Cardápio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css"> </head>
<body class="bg-dark text-white">

<header class="bg-warning text-dark text-center py-4 mb-4 shadow">
    <h1 class="fw-bold mb-0">🍕 Pizza Itália</h1>
    <p class="mb-0 fw-semibold">Faça seu pedido online de forma rápida!</p>
</header>

<div class="container-fluid px-4 mb-5">
    <div class="row g-4">
        
        <div class="col-lg-8">
            <h3 class="mb-4 text-warning fw-bold"><i class="fas fa-pizza-slice me-2"></i>Nosso Cardápio</h3>
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4" id="listaProdutos">
                </div>
        </div>

        <div class="col-lg-4">
            <div class="card bg-secondary text-white border-light position-sticky" style="top: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
                <div class="card-header bg-dark text-warning d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-shopping-cart me-2"></i>Seu Carrinho</h5>
                    <span class="badge bg-warning text-dark id" id="contadorItens">0 itens</span>
                </div>
                
                <div class="card-body p-3" style="max-height: 400px; overflow-y: auto;" id="itensCarrinho">
                    <p class="text-center text-muted my-4">Seu carrinho está vazio.</p>
                </div>

                <div class="card-footer bg-dark p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fs-5 fw-bold text-white">Total:</span>
                        <span class="fs-4 fw-bold text-success" id="totalCarrinho">R$ 0,00</span>
                    </div>
                    <button class="btn btn-warning w-100 btn-lg fw-bold" id="btnFinalizar" onclick="registrarPedido()" disabled>
                        <i class="fas fa-check me-2"></i>Finalizar Pedido
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="/js/cliente.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>