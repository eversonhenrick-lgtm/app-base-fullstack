<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pizzaria - Novo Produto</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="body-sistema-pizzaria">

    <div class="container d-flex flex-column align-items-center justify-content-center min-vh-100 py-5">
        
        <div class="painel-principal w-100 mb-5" style="max-width: 550px; margin-top: 0;">
            
            <div class="mb-4 text-center">
                <h3 class="fw-bold"><i class="fas fa-pizza-slice me-2"></i>Cadastrar Produto</h3>
                <p style="color: #94a3b8; font-size: 0.95rem;">Adicione novos itens e valores ao cardápio</p>
                <hr style="border-color: #334155; opacity: 0.5;">
            </div>

            <form id="formProduto">
                
                <div class="mb-3">
                    <label for="nome" class="form-label fw-semibold" style="color: white;">Nome do Produto</label>
                    <input type="text" class="form-control" id="nome" name="nome" placeholder="Ex: Pizza de Calabresa" required>
                </div>

                <div class="row">
                    <div class="col-6 mb-3">
                        <label for="categoria" class="form-label fw-semibold" style="color: white;">Categoria</label>
                        <select class="form-select form-control" id="categoria" name="categoria" required>
                            <option value="" disabled selected style="background: #1e293b;">Escolha...</option>
                            <option value="Pizza" style="background: #1e293b;">Pizzas</option>
                            <option value="Bebida" style="background: #1e293b;">Bebidas</option>
                        </select>
                    </div>

                    <div class="col-6 mb-3">
                        <label for="preco" class="form-label fw-semibold" style="color: white;">Preço (R$)</label>
                        <input type="number" class="form-control" id="preco" name="preco" step="0.01" placeholder="45.90" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="imagem" class="form-label fw-semibold" style="color: white;">Link da Imagem (URL)</label>
                    <input type="url" class="form-control" id="imagem" name="imagem" placeholder="https://exemplo.com/foto.jpg">
                </div>

                <div class="mb-4">
                    <label for="descricao" class="form-label fw-semibold" style="color: white;">Descrição / Ingredientes</label>
                    <textarea class="form-control" id="descricao" name="descricao" rows="3" placeholder="Molho de tomate, mussarela, calabresa picada..."></textarea>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-warning btn-lg py-3">
                        Adicionar ao Cardápio
                    </button>
                </div>

            </form>
        </div>

        <div class="w-100 mt-2">
            <h3 class="text-center mb-4 fw-bold" style="color: #ffc107;">Cardápio Pizza Itália</h3>
            
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="listaProdutos">
                </div>
        </div>

    </div>

    <script src="/js/produtos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>